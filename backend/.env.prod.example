# ── Django ────────────────────────────────────────────────────────────────────
SECRET_KEY=CHANGE_ME_generate_with_python3_-c_"import_secrets;print(secrets.token_urlsafe(50))"
DEBUG=False
ALLOWED_HOSTS=yourdomain.com,www.yourdomain.com
DJANGO_SETTINGS_MODULE=config.settings.production

# ── Database (set in docker-compose.prod.yml via DATABASE_URL) ────────────────
POSTGRES_DB=medical_store
POSTGRES_USER=msm_user
POSTGRES_PASSWORD=CHANGE_ME_strong_password_here

# ── JWT ───────────────────────────────────────────────────────────────────────
JWT_ACCESS_TOKEN_LIFETIME_MINUTES=60
JWT_REFRESH_TOKEN_LIFETIME_DAYS=7

# ── CORS ──────────────────────────────────────────────────────────────────────
CORS_ALLOWED_ORIGINS=https://yourdomain.com,https://www.yourdomain.com
FRONTEND_URL=https://yourdomain.com

# ── AWS S3 (for prescription file uploads — optional) ────────────────────────
# If not using S3, leave blank and files store locally in /app/media
AWS_ACCESS_KEY_ID=
AWS_SECRET_ACCESS_KEY=
AWS_STORAGE_BUCKET_NAME=
AWS_S3_REGION_NAME=us-east-1
